# Env file for docker-compose deployment. Copy this file to .env and fill in your values.

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ogstack

# ---------- Authentication ----------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=30d

# ---------- CORS ----------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5001

# ---------- Logging ----------
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ---------- File Uploads ----------
UPLOAD_DIR=./uploads

# ---------- Seed ----------
ADMIN_EMAIL=<PLACEHOLDER>
ADMIN_PASSWORD=<PLACEHOLDER>

# ---------- Email (Resend) ----------
RESEND_API_KEY=<PLACEHOLDER>
EMAIL_FROM_NAME="OGStack Team"
EMAIL_FROM_ADDRESS=noreply@ogstack.dev
WEBSITE_URL=http://localhost:5001

# ---------- Cloudflare R2 (optional, uses local storage if not set) ----------
R2_ACCOUNT_ID=<PLACEHOLDER>
R2_BUCKET_NAME=ogstack
R2_ACCESS_KEY_ID=<PLACEHOLDER>
R2_SECRET_ACCESS_KEY=<PLACEHOLDER>
R2_PUBLIC_URL=<PLACEHOLDER>

# ---------- Stripe ----------
STRIPE_SECRET_KEY=<PLACEHOLDER>
STRIPE_WEBHOOK_SECRET=<PLACEHOLDER>

# ---------- FAL.ai (Flux image generation) ----------
FAL_API_KEY=<PLACEHOLDER>

# ---------- Prompt Provider (LLM that rewrites page metadata into visual keywords) ----------
# Set to: anthropic | openai | deepseek | ollama | llamacpp | claude-code
PROMPT_PROVIDER=

# Anthropic (Claude)
ANTHROPIC_API_KEY=<PLACEHOLDER>
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=<PLACEHOLDER>
OPENAI_MODEL=gpt-5.4

# DeepSeek
DEEPSEEK_API_KEY=<PLACEHOLDER>
DEEPSEEK_MODEL=deepseek-chat

# Ollama (local) — set base URL to enable, e.g. http://localhost:11434
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# llama.cpp server (local) — set base URL to enable, e.g. http://localhost:8080
LLAMACPP_BASE_URL=
LLAMACPP_MODEL=gemma4

# Claude Code CLI (dev only) — uses your local `claude -p` subscription.
CLAUDE_CODE_ENABLED=
CLAUDE_CODE_MODEL=opus-4-7

# ---------- Headless Render Provider (optional, for SPA / JS-rendered pages) ----------
# Set to: browserless | scrapingbee | none (default: none)
RENDER_PROVIDER=

# Browserless (https://www.browserless.io) — self-hosted or cloud
BROWSERLESS_URL=
BROWSERLESS_TOKEN=

# ScrapingBee (https://www.scrapingbee.com)
SCRAPINGBEE_API_KEY=

