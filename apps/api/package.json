{
  "name": "@ogstack/api",
  "version": "1.0.0",
  "private": true,
  "module": "src/index.js",
  "types": "./dist/apps/api/src/app.d.ts",
  "scripts": {
    "test": "bun run test",
    "dev": "bun run --watch src/app.ts",
    "start": "bun run src/app.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --create-only",
    "db:migrate:apply": "prisma migrate deploy",
    "db:seed": "bun run prisma/seed/index.ts",
    "build:linux": "bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile dist/server src/app.ts",
    "build:win": "bun build --compile --minify-whitespace --minify-syntax --target bun-windows-x64 --outfile dist/server.exe src/app.ts",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "generate:thumbnails": "bun run scripts/generate-template-thumbnails.ts"
  },
  "prisma": {
    "seed": "bun run prisma/seed/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "@google-cloud/recaptcha-enterprise": "^6.4.0",
    "@ogstack/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/client-runtime-utils": "^7.7.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@resvg/resvg-js": "^2.6.2",
    "@sinclair/typebox": "^0.34.49",
    "dotenv": "^17.4.1",
    "elysia": "^1.4.28",
    "fflate": "^0.8.2",
    "jose": "6.1.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "png-to-ico": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.10.0",
    "satori": "^0.26.0",
    "stripe": "^22.0.1",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "prisma": "^7.7.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2"
  }
}
