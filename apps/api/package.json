{
  "name": "@ogstack/api",
  "version": "1.0.0",
  "private": true,
  "module": "src/index.js",
  "types": "./dist/apps/api/src/app.d.ts",
  "scripts": {
    "test": "bun run test",
    "dev": "bun run --watch src/app.ts",
    "start": "bun run src/app.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --create-only",
    "db:migrate:apply": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "build:linux": "bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile dist/server src/app.ts",
    "build:win": "bun build --compile --minify-whitespace --minify-syntax --target bun-windows-x64 --outfile dist/server.exe src/app.ts",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "bun run prisma/seed/index.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "@ogstack/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/client-runtime-utils": "^7.5.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@sinclair/typebox": "^0.34.48",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.28",
    "jose": "6.1.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.4",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^7.5.0",
    "typescript": "^5.9.3"
  }
}
