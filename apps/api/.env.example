# Copy this file to .env and fill in your values.

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ogstack

# ---------- Authentication ----------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=30d

# ---------- Server ----------
PORT=4000
NODE_ENV=development

# ---------- CORS ----------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4001,http://localhost:8081

# ---------- Logging ----------
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ---------- File Uploads ----------
UPLOAD_DIR=./uploads

# ---------- Seed ----------
ADMIN_EMAIL=<PLACEHOLDER>
ADMIN_PASSWORD=<PLACEHOLDER>

# ---------- Email (Resend) ----------
RESEND_API_KEY=<PLACEHOLDER>
EMAIL_FROM_NAME="OGStack Team"
EMAIL_FROM_ADDRESS=noreply@ogstack.dev
WEBSITE_URL=http://localhost:4001

# ---------- Cloudflare R2 (optional, uses local storage if not set) ----------
R2_ACCOUNT_ID=<PLACEHOLDER>
R2_BUCKET_NAME=ogstack-images
R2_ACCESS_KEY_ID=<PLACEHOLDER>
R2_SECRET_ACCESS_KEY=<PLACEHOLDER>
R2_PUBLIC_URL=<PLACEHOLDER>

