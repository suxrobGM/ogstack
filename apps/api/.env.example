# Copy this file to .env and fill in your values.

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ogstack

# ---------- Authentication ----------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=30d

# ---------- Server ----------
PORT=4000
NODE_ENV=development

# ---------- CORS ----------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4001,http://localhost:8081

# ---------- Logging ----------
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ---------- File Uploads ----------
UPLOAD_DIR=./uploads

# ---------- Seed ----------
ADMIN_EMAIL=<PLACEHOLDER>
ADMIN_PASSWORD=<PLACEHOLDER>

# ---------- Email (Resend) ----------
RESEND_API_KEY=<PLACEHOLDER>
EMAIL_FROM_NAME="OGStack Team"
EMAIL_FROM_ADDRESS=noreply@ogstack.dev
WEBSITE_URL=http://localhost:4001

# ---------- Cloudflare R2 (optional, uses local storage if not set) ----------
R2_ACCOUNT_ID=<PLACEHOLDER>
R2_BUCKET_NAME=ogstack
R2_ACCESS_KEY_ID=<PLACEHOLDER>
R2_SECRET_ACCESS_KEY=<PLACEHOLDER>
R2_PUBLIC_URL=<PLACEHOLDER>

# ---------- Stripe ----------
STRIPE_SECRET_KEY=<PLACEHOLDER>
STRIPE_WEBHOOK_SECRET=<PLACEHOLDER>

# ---------- FAL.ai (Flux image generation) ----------
FAL_API_KEY=<PLACEHOLDER>
FAL_TIMEOUT_MS=7000

# ---------- Prompt Provider (LLM that rewrites page metadata into visual keywords) ----------
# Optional. When unset, the first configured provider below is used. Set to one
# of: anthropic | openai | deepseek | ollama | llamacpp
PROMPT_PROVIDER=
PROMPT_PROVIDER_TIMEOUT_MS=2500

# Anthropic (Claude)
ANTHROPIC_API_KEY=<PLACEHOLDER>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_BASE_URL=

# OpenAI
OPENAI_API_KEY=<PLACEHOLDER>
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=https://api.openai.com

# DeepSeek
DEEPSEEK_API_KEY=<PLACEHOLDER>
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama (local) — set base URL to enable, e.g. http://localhost:11434
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# llama.cpp server (local) — set base URL to enable, e.g. http://localhost:8080
LLAMACPP_BASE_URL=
LLAMACPP_API_KEY=
LLAMACPP_MODEL=local-model

